# ============================================================
# Transcritor Local - Environment Variables
# Copy this file to .env and fill in your own credentials.
# ============================================================

# --- Supabase (required) ---
# Create a project at https://supabase.com and run supabase/schema.sql
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=YOUR-SUPABASE-ANON-KEY

# --- LLM provider for ATA generation (at least one required) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Default provider when both keys are present: "openrouter" | "openai"
ATA_PROVIDER=openrouter

# Max characters of transcript sent to the LLM (truncated if longer)
ATA_MAX_CHARS=20000

# --- Speaker diarization (optional) ---
# Get a token at https://huggingface.co/settings/tokens
# and accept pyannote/speaker-diarization-3.1 terms.
HF_TOKEN=

# --- Whisper transcription engine ---
# tiny | base | small | medium | large-v3 | distil-large-v3
TRANSCRIBE_MODEL=medium

# auto | cuda | cpu
TRANSCRIBE_DEVICE=auto
TRANSCRIBE_DEVICE_INDEX=0

# Language hint (ISO 639-1). Leave blank for auto-detection.
TRANSCRIBE_LANGUAGE=pt
